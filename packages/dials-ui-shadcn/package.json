{
  "name": "@zodal/dials-ui-shadcn",
  "version": "0.1.0",
  "description": "React/shadcn renderer for @zodal/dials-ui — settings panel components consuming the headless config",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }, "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" } } },
  "publishConfig": { "access": "public" },
  "files": ["dist"],
  "scripts": { "build": "tsup", "prepublishOnly": "pnpm build", "test": "vitest run", "typecheck": "tsc --noEmit" },
  "peerDependencies": {
    "@zodal/core": "^0.1.2",
    "@zodal/dials-core": "^0.1.0",
    "@zodal/dials-ui": "^0.1.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@zodal/core": "^0.1.2",
    "@zodal/dials-core": "workspace:*",
    "@zodal/dials-ui": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "jsdom": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

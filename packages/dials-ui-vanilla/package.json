{
  "name": "@zodal/dials-ui-vanilla",
  "version": "0.1.0",
  "description": "Vanilla HTML/JS reference renderer for @zodal/dials-ui — no framework, produces DOM from the headless settings config",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "publishConfig": { "access": "public" },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@zodal/core": "^0.1.2",
    "@zodal/dials-core": "^0.1.0",
    "@zodal/dials-ui": "^0.1.0",
    "zod": ">=4.1.13"
  },
  "devDependencies": {
    "@zodal/core": "^0.1.2",
    "@zodal/dials-core": "workspace:*",
    "@zodal/dials-ui": "workspace:*",
    "jsdom": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^4.4.0"
  }
}

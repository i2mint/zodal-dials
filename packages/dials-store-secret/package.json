{
  "name": "@zodal/dials-store-secret",
  "version": "0.1.0",
  "description": "Secret backend + bifurcation provider for zodal-dials — routes secret values to a separate backend (content/metadata bifurcation)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }, "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" } } },
  "publishConfig": { "access": "public" },
  "files": ["dist"],
  "scripts": { "build": "tsup", "prepublishOnly": "pnpm build", "test": "vitest run", "typecheck": "tsc --noEmit" },
  "peerDependencies": { "@zodal/core": "^0.1.2", "@zodal/dials-core": "^0.1.0" },
  "devDependencies": { "@zodal/core": "^0.1.2", "@zodal/dials-core": "workspace:*", "tsup": "^8.0.0", "typescript": "^5.7.0", "vitest": "^3.0.0" }
}

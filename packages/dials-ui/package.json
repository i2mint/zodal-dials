{
  "name": "@zodal/dials-ui",
  "version": "0.1.0",
  "description": "Headless settings UI layer for zodal-dials: toSettingsForm, the settings renderer registry, facet grouping, search, and change-lifecycle events",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@zodal/core": "^0.1.2",
    "@zodal/dials-core": "^0.1.0",
    "@zodal/ui": "^0.1.2",
    "zod": ">=4.1.13"
  },
  "devDependencies": {
    "@zodal/core": "^0.1.2",
    "@zodal/dials-core": "workspace:*",
    "@zodal/ui": "^0.1.2",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^4.4.0"
  }
}

{
  "name": "@zodal/dials-store-jsonc",
  "version": "0.1.0",
  "description": "JSONC-file LayerStore for zodal-dials with format-preserving writes (VS Code settings.json style)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }, "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" } } },
  "publishConfig": { "access": "public" },
  "files": ["dist"],
  "scripts": { "build": "tsup", "prepublishOnly": "pnpm build", "test": "vitest run", "typecheck": "tsc --noEmit" },
  "dependencies": { "jsonc-parser": "^3.3.1" },
  "peerDependencies": { "@zodal/core": "^0.1.2", "@zodal/dials-core": "^0.1.0" },
  "devDependencies": { "@zodal/core": "^0.1.2", "@zodal/dials-core": "workspace:*", "@types/node": "^22.0.0", "tsup": "^8.0.0", "typescript": "^5.7.0", "vitest": "^3.0.0" }
}
